{
  "WorkspaceRoot": "workspaces",
  "RepositoryPolicy": {
    "AllowedHosts": [
      "github.com"
    ],
    "AllowedOwners": [
      "example-company"
    ],
    "DisallowedHosts": [
    ],
    "DisallowedOwners": [
    ]
  },
  "Git": {
    "CloneTimeoutSeconds": 120,
    "PushTimeoutSeconds": 120
  },
  "GitHub": {
    "TokenEnvironmentVariable": "GITHUB_TOKEN",
    "ApiBaseUrl": "https://api.github.com"
  },
  "Ai": {
    "Provider": "OpenAI",
    "Model": "gpt-5.4",
    "OpenAiApiBaseUrl": "https://api.openai.com",
    "GeminiApiBaseUrl": "https://generativelanguage.googleapis.com",
    "MaxContextFiles": 50,
    "MaxFileBytes": 100000,
    "MaxChangedFiles": 50,
    "MaxCriticalSignatures": 50,
    "RequestTimeoutSeconds": 300,
    "MaxTestFixAttempts": 1
  },
  "BuildRunner": {
    "TimeoutSeconds": 180,
    "MaxOutputChars": 8000
  },
  "TestRunner": {
    "TimeoutSeconds": 120,
    "MaxOutputChars": 8000
  },
  "AsyncExecution": {
    "QueueCapacity": 100
  },
  "ExecutionReports": {
    "Directory": "execution-reports"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "FilePath": "logs"
  },
  "AllowedHosts": "*"
}
